# NOAA Climate Data Online
# Obtenha em: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=your_noaa_token_here

# NYC Open Data API
# Obtenha em: https://data.cityofnewyork.us/profile/app_tokens
NYC_APP_TOKEN=your_nyc_app_token_here
NYC_APP_SECRET=your_nyc_app_secret_here

# Microsoft Fabric tenant (apenas referência, não é secret)
FABRIC_TENANT=your_tenant.onmicrosoft.com
